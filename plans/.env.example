# TTS API Configuration
# Configure your TTS service endpoint and authentication
TTS_API_ENDPOINT=https://api.example.com/v1/tts
TTS_API_KEY=your-api-key-here

# Directory Configuration
# These paths should match the installation directory structure
# Default: /opt/private-reading/{input,output,processed}
INPUT_DIR=/opt/private-reading/input
OUTPUT_DIR=/opt/private-reading/output
PROCESSED_DIR=/opt/private-reading/processed

# Logging Configuration
# Available levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output format: json (structured) or text (human-readable)
LOG_FORMAT=json

# Service Configuration
# User/group under which the Private Reading service runs
SERVICE_USER=private-reading
SERVICE_GROUP=private-reading

# Additional Configuration
# Enable debug mode for detailed logging during development
DEBUG_MODE=false

# Max concurrent jobs (optional)
MAX_CONCURRENT_JOBS=4

# Audio processing settings
# Sample rate for output audio (in Hz)
AUDIO_SAMPLE_RATE=44100

# Output audio format (optional, default: mp3)
OUTPUT_FORMAT=mp3

# Chunking settings for text processing
# Maximum chunk size in characters
CHUNK_SIZE=1000

# Overlap between chunks (optional)
CHUNK_OVERLAP=50
