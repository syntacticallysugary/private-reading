# Copy this file to .env and fill in your values.
# docker-compose.yml loads .env automatically.

# ── TTS service ───────────────────────────────────────────────────────────────

# TTS Provider: 'fish' or 'qwen'
TTS_PROVIDER=fish

# Endpoint of your TTS inference server.
# Fish default: http://192.168.1.104:8013/v1/tts
# Qwen default: http://192.168.1.104:8008/v1/audio/speech
TTS_ENDPOINT=http://192.168.1.104:8013/v1/tts

# --- Provider-specific settings ---

# 1. Fish TTS & Qwen Base: Pre-registered voice reference ID.
# Leave blank for server default voice.
TTS_REFERENCE_ID=

# 2. Qwen VoiceDesign: Natural language voice design prompt.
# Describe timbre, tone, pacing, emotion.
TTS_VOICE=

# 3. Qwen model name (used for OpenAI-compatible schema)
TTS_MODEL=qwen

# --- Generation parameters (Shared) ---
TTS_TEMPERATURE=0.8

# --- Generation parameters (Fish-specific) ---
TTS_TOP_P=0.8
TTS_REPETITION_PENALTY=1.1

# --- Reliability settings ---
TTS_RETRY_ATTEMPTS=3
TTS_BASE_BACKOFF_MS=1000

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Format: json (structured) | text (human-readable)
LOG_FORMAT=json

# ── Processing ────────────────────────────────────────────────────────────────
# Maximum characters per TTS chunk (default 500)
PROCESSING_CHUNK_SIZE=500
# Overlap between consecutive chunks, 0.0–1.0 (default 0.1)
PROCESSING_OVERLAP_RATIO=0.1

# ── Semaphore ─────────────────────────────────────────────────────────────────
# Concurrency control for parallel processing (default 10, valid range 1-50)
SEMAPHORE_SIZE=10
