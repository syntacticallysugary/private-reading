# Copy this file to .env and fill in your values.
# docker-compose.yml loads .env automatically.

# ── TTS service ───────────────────────────────────────────────────────────────
# Endpoint of your Qwen TTS inference server.
TTS_ENDPOINT=http://192.168.1.104:8008/v1/audio/speech
# Natural language voice design prompt (leave blank for server default voice).
# Describe timbre, tone, pacing, emotion — the more specific, the better.
# Example: "A warm, enthusiastic female teacher in her 30s, speaks with a
#           friendly tone, uses natural pauses, and sounds encouraging."
TTS_VOICE_DESIGN=A warm, friendly, intimate and energetic middle aged male narrator.

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Format: json (structured) | text (human-readable)
LOG_FORMAT=json

# ── Processing ────────────────────────────────────────────────────────────────
# Maximum characters per TTS chunk (default 500)
PROCESSING_CHUNK_SIZE=500
# Overlap between consecutive chunks, 0.0–1.0 (default 0.1)
PROCESSING_OVERLAP_RATIO=0.1

# ── Semaphore ─────────────────────────────────────────────────────────────────
# Concurrency control for parallel processing (default 10, valid range 1-50)
SEMAPHORE_SIZE=10
