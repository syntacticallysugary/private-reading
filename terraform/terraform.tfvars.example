# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.
# In CI/CD these are injected as TF_VAR_* environment variables instead.

# OCI identity
oci_tenancy_ocid     = "ocid1.tenancy.oc1..example"
oci_user_ocid        = "ocid1.user.oc1..example"
oci_fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
# Paste the contents of your OCI API signing key PEM file here (the full
# multi-line PEM block including the BEGIN/END headers).
oci_private_key      = "PASTE_YOUR_OCI_PRIVATE_KEY_PEM_HERE"
oci_region           = "us-ashburn-1"
oci_compartment_ocid = "ocid1.compartment.oc1..example"

# AWS identity (for Cognito app client)
aws_region           = "us-east-1"

# Cognito — ID of the User Pool managed by Know-It-All CloudFormation stack
cognito_user_pool_id = "us-east-1_AbCdEfGhI"

# Job store (FastAPI + SQLite service on ARM VM)
job_store_url     = "http://10.0.0.248:8000"
job_store_api_key = "GENERATE_A_RANDOM_SECRET"

# Application
app_name    = "private-reading"
environment = "prod"

# k3s cluster (fill in after cluster is bootstrapped)
k8s_host                   = "https://192.168.1.x:6443"
k8s_cluster_ca_certificate = "BASE64_ENCODED_CA_CERT"
k8s_client_certificate     = "BASE64_ENCODED_CLIENT_CERT"
k8s_client_key             = "BASE64_ENCODED_CLIENT_KEY"

# Worker push notifications via WireGuard VPN (optional — omit to use polling only)
worker_webhook_url    = "http://192.168.1.105:8765/notify"
worker_webhook_secret = "GENERATE_A_RANDOM_SECRET"
