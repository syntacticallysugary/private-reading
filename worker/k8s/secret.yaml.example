apiVersion: v1
kind: Secret
metadata:
  name: private-reading-worker-secrets
  namespace: private-reading
type: Opaque
data:
  # Base64 encoded WORKER_API_KEY
  WORKER_API_KEY: "<BASE64_ENCODED_KEY>"
  # Base64 encoded shared secret for the webhook receiver (X-Webhook-Secret header)
  WEBHOOK_SECRET: "<BASE64_ENCODED_SECRET>"

---
apiVersion: v1
kind: Secret
metadata:
  name: private-reading-oci-config
  namespace: private-reading
type: Opaque
data:
  # Base64 encoded ~/.oci/config and the private key.
  # IMPORTANT: the config file must set key_file=/home/worker/.oci/key.pem
  # (not /root/.oci/key.pem) because the worker runs as UID 1000.
  config: "<BASE64_ENCODED_CONFIG>"
  key.pem: "<BASE64_ENCODED_PRIVATE_KEY>"
